<div class="mt-4 border-t border-gray-200 pt-3">
  <% if exercise_record.comments.any? %>
    <div class="space-y-2">
      <% exercise_record.comments.sort_by(&:created_at).each do |comment| %>
        <div class="rounded-lg bg-white px-3 py-2 shadow-sm">
          <div class="mb-1 flex items-center justify-between gap-2">
            <p class="text-sm font-semibold text-gray-700">
              <%= comment.user.name %>
            </p>

            <p class="text-xs text-gray-500">
              <%= l comment.created_at, format: :short %>
            </p>
          </div>

          <p class="text-sm leading-relaxed text-gray-800">
            <%= comment.body %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>

  <details class="mt-3">
    <summary class="inline-flex cursor-pointer rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-600 hover:bg-green-100 hover:text-green-700">
      コメントする
    </summary>

    <div class="mt-3">
      <%= form_with model: [exercise_record, Comment.new], local: true do |f| %>
        <%= f.text_area :body,
                        rows: 2,
                        maxlength: 100,
                        placeholder: "コメントを書く",
                        class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500" %>

        <div class="mt-2 text-right">
          <%= f.submit "投稿",
                       class: "rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700" %>
        </div>
      <% end %>
    </div>
  </details>
</div>

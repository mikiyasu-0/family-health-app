<div class="mx-auto max-w-2xl space-y-6 p-4">
  <h1 class="text-2xl font-bold text-gray-900">
    <%= @user.name %>さんの運動履歴
  </h1>

  <% if @records_by_date.any? %>
    <% @records_by_date.each do |date, records| %>
      <section class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-bold text-gray-800">
          <%= date.strftime("%Y-%m-%d") %>
        </h2>

        <div class="mt-4 space-y-3">
          <% records.each do |record| %>
            <div class="rounded-xl bg-gray-50 p-4">
              <p class="text-base font-semibold text-gray-800">
                <% case record.exercise_type %>
                <% when "walk" %>
                  散歩
                <% when "chair_squat" %>
                  椅子スクワット
                <% when "heel_raise" %>
                  かかと上げ
                <% when "rest" %>
                  休み
                <% end %>
              </p>

              <p class="mt-2 text-sm leading-relaxed text-gray-600">
                <%= record.memo.presence || "メモはありません" %>
              </p>

              <div class="mt-2 flex gap-3">

                <% if @user == current_user %>
                  <!-- 自分の履歴：件数のみ -->
                  <% Reaction::REACTION_EMOJIS.each do |reaction_type, emoji| %>
                    <% count = record.reactions.where(reaction_type: reaction_type).count %>

                    <% if count > 0 %>
                      <span class="px-2 py-1 bg-gray-100 text-base font-medium text-gray-700 rounded-full">
                        <%= emoji %> <%= count %>
                      </span>
                    <% end %>
                  <% end %>
                <% else %>
                  <!-- 他人の履歴：ボタンあり -->
                  <% Reaction::REACTION_EMOJIS.each do |reaction_type, emoji| %>

                    <% reacted = record.reactions.where(
                      user_id: current_user.id,
                      reaction_type: reaction_type
                    ).exists? %>

                    <div class="flex items-center gap-1 px-2 py-1 text-base font-medium rounded-full
                      <%= reacted ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">

                      <%= button_to emoji, reactions_path,
                          params: {
                            exercise_record_id: record.id,
                            reaction_type: reaction_type
                          },
                          form_class: "inline",
                          class: "inline" %>

                      <% count = record.reactions.where(reaction_type: reaction_type).count %>

                      <% if count > 0 %>
                        <span><%= count %></span>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  <% else %>
    <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 p-5 text-sm text-gray-500">
      運動履歴はまだありません
    </div>
  <% end %>
</div>

<div class="min-h-screen bg-gray-50 px-4 py-10">
  <div class="mx-auto max-w-3xl">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-800">グループ一覧</h1>
      <p class="mt-2 text-sm text-gray-500">所属しているグループを確認できます</p>
    </div>

    <% if @groups.any? %>
      <div class="space-y-4">
        <%= render @groups %>
      </div>
    <% else %>
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-10 text-center shadow-sm">
        <p class="text-gray-600">所属しているグループはまだありません</p>
      </div>
    <% end %>
  </div>
</div>

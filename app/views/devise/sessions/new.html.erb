<div class="min-h-screen bg-orange-50 flex items-center justify-center px-4 py-8">
  <div class="w-full max-w-lg bg-white rounded-2xl shadow-md p-8 md:p-10 border border-orange-100">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-3">ログイン</h1>
    <p class="text-base text-center text-gray-700 mb-8 leading-relaxed">
      登録済みのメールアドレスとパスワードを入力してください
    </p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <div>
        <%= f.label :email, "メールアドレス", class: "block text-base font-semibold text-gray-800 mb-2" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "例：familystep@example.com",
              class: "w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-base text-gray-800 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "block text-base font-semibold text-gray-800 mb-2" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "パスワードを入力してください",
              class: "w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-base text-gray-800 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-3">
          <%= f.check_box :remember_me, class: "h-5 w-5 rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "text-base text-gray-700" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "ログインする",
              class: "w-full rounded-xl bg-teal-600 hover:bg-teal-700 text-white text-lg font-bold py-4 transition" %>
      </div>
    <% end %>

    <div class="mt-8 space-y-3 text-center text-base text-gray-700">
      <div>
        アカウントをお持ちでない方は
        <%= link_to "新規登録はこちら", new_registration_path(resource_name), class: "font-semibold text-teal-700 underline underline-offset-2 hover:text-teal-800" %>
      </div>

      <% if devise_mapping.recoverable? %>
        <div>
          パスワードをお忘れの方は
          <%= link_to "こちら", new_password_path(resource_name), class: "font-semibold text-teal-700 underline underline-offset-2 hover:text-teal-800" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<section class="mx-auto max-w-md">
  <div class="rounded-2xl bg-white px-6 py-8 shadow-md">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-gray-800">
        パスワードをお忘れですか？
      </h2>

      <p class="mt-3 text-sm leading-6 text-gray-600">
        登録しているメールアドレスを入力してください。<br>
        パスワード再設定用のメールをお送りします。
      </p>
    </div>

    <div class="mt-6">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "shared/error_messages", object: resource %>

        <div>
          <%= f.label :email, "メールアドレス", class: "block text-sm font-semibold text-gray-700" %>

          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "登録しているメールアドレスを入力",
              class: "mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 text-base focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-200" %>
        </div>

        <div class="mt-6">
          <%= f.submit "再設定メールを送信する",
              class: "w-full rounded-xl bg-teal-600 px-5 py-3 text-base font-semibold text-white shadow-sm hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-teal-300" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to "ログイン画面に戻る",
          new_user_session_path,
          class: "text-sm font-semibold text-teal-700 underline" %>
    </div>
  </div>
</section>

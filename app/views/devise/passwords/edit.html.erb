<section class="mx-auto max-w-md">
  <div class="rounded-2xl bg-white px-6 py-8 shadow-md">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-gray-800">
        新しいパスワードを設定する
      </h2>

      <p class="mt-3 text-sm leading-6 text-gray-600">
        新しく使うパスワードを入力してください。<br>
        次回からこのパスワードでログインできます。
      </p>
    </div>

    <div class="mt-6">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "shared/error_messages", object: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div>
          <%= f.label :password, "新しいパスワード", class: "block text-sm font-semibold text-gray-700" %>

          <% if @minimum_password_length %>
            <p class="mt-1 text-sm text-gray-500">
              <%= @minimum_password_length %>文字以上で入力してください
            </p>
          <% end %>

          <%= f.password_field :password,
              autofocus: true,
              autocomplete: "new-password",
              placeholder: "新しいパスワードを入力",
              class: "mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 text-base focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-200" %>
        </div>

        <div class="mt-5">
          <%= f.label :password_confirmation, "新しいパスワード（確認用）", class: "block text-sm font-semibold text-gray-700" %>

          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "もう一度パスワードを入力",
              class: "mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 text-base focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-200" %>
        </div>

        <div class="mt-6">
          <%= f.submit "パスワードを変更する",
              class: "w-full rounded-xl bg-teal-600 px-5 py-3 text-base font-semibold text-white shadow-sm hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-teal-300" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to "ログイン画面に戻る",
          new_user_session_path,
          class: "text-sm font-semibold text-teal-700 underline" %>
    </div>
  </div>
</section>

<div class="mx-auto max-w-2xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">マイページ</h1>
    <p class="mt-2 text-sm text-gray-500">登録情報を確認できます。</p>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
    <div class="space-y-4">
      <div>
        <p class="text-sm font-medium text-gray-500">名前</p>
        <p class="mt-1 text-base font-semibold text-gray-800"><%= @user.name %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-500">メールアドレス</p>
        <p class="mt-1 text-base font-semibold text-gray-800"><%= @user.email %></p>
      </div>
    </div>

    <% if current_user.guest? %>
      <p class="mt-6 text-sm text-gray-500">
        ゲストユーザーは編集できません
      </p>
    <% else %>
      <div class="mt-6">
        <%= link_to "編集する",
                    edit_user_registration_path,
                    class: "inline-flex items-center rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-700" %>
      </div>
    <% end %>

    <% if admin_user? %>
      <div class="mt-8 rounded-2xl border border-red-200 bg-red-50 p-5">
        <h2 class="text-base font-bold text-red-700">
          管理者メニュー
        </h2>

        <p class="mt-2 text-sm text-red-600">
          作成から一定期間が経過したゲストユーザーと関連データを削除します。
        </p>

        <%= button_to "古いゲストデータを削除する",
                      admin_guest_user_cleanup_path,
                      method: :post,
                      data: { turbo_confirm: "古いゲストユーザーと関連データを削除します。実行しますか？" },
                      class: "mt-4 rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700" %>
      </div>
    <% end %>
  </div>
</div>
